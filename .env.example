# 知识库环境配置文件
# 将此文件重命名为 .env 并填写以下配置

# ─── LLM API ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，用于代理或本地兼容服务

# ─── 模型选择 ────────────────────────────────────────────
COMPILE_MODEL=gpt-4o          # 摘要编译模型
ONTOLOGY_MODEL=gpt-4o-mini    # 本体抽取模型（经济型）
RELATE_MODEL=gpt-4o           # 关系检测模型
SEARCH_MODEL=gpt-4o           # 检索回答模型

# ─── 性能参数 ────────────────────────────────────────────
RELATE_MAX_COMPARE=50         # 关系检测时最多对比文档数

# ─── 思考开关 (Big-Loop #5, qwen3 系列思考模型适用) ──────────────────────
# 默认关(false)以加速:Layer2 评分 4-5x、Layer3 首 token 70x(实测 Top 召回不降)。
# 设 true 开回深度推理模式(更慢但判断更深)。
# ANSWER_ENABLE_THINKING=false   # Layer3 回答生成
# SCORE_ENABLE_THINKING=false    # Layer2 相关性评分
